{
  "version": 2,

  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },

    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },

    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },

    {
      "src": "/",
      "dest": "/frontend/landing.html"
    },

    {
      "src": "/landing",
      "dest": "/frontend/landing.html"
    },

    {
      "src": "/login",
      "dest": "/frontend/auth.html"
    },

    {
      "src": "/signup",
      "dest": "/frontend/auth.html"
    },

    {
      "src": "/onboarding",
      "dest": "/frontend/onboarding.html"
    },

    {
      "src": "/app",
      "dest": "/frontend/index.html"
    },

    {
      "src": "/master/login",
      "dest": "/frontend/auth.html"
    },

    {
      "src": "/(.*)",
      "dest": "/frontend/landing.html"
    }
  ]
}